use lib.runarorama_sqlite_1_0_1 Sqlite
use lib.unison_http_16_1_0 HttpRequest HttpResponse Body Version Headers
use lib.unison_http_16_1_0.server Config Routes Handler
use lib.unison_http_16_1_0.client Http
use lib.unison_json_1_4_2.core Json
use lib.unison_json_1_4_2 Decoder
use lib.guillaumedesforges_restate_sdk_unison_main Restate
use lib.guillaumedesforges_restate_sdk_unison_main.Restate.Ctx ctx
use lib.guillaumedesforges_restate_sdk_unison_main.Restate AwakeableHandle Input HandlerDef ServiceDef Endpoint
use lib.guillaumedesforges_restate_sdk_unison_main.Restate.NotifValue NSuccess NFailure NVoid
use lib.guillaumedesforges_restate_sdk_unison_main.Restate.ServiceKind RsService

-- ============================================================
-- Domain types
-- ============================================================

type ContentId = ContentId Text

type Content = { id : ContentId, authorId : Text, text : Text, createdAt : Nat, status : ContentStatus }

type ContentStatus
  = Submitted
  | AutoModerated ModerationDecision
  | PendingHumanReview ModerationDecision
  | Resolved ModerationDecision

type ModerationDecision
  = Approve
  | Reject Text
  | Escalate Text

ContentId.unwrap : ContentId -> Text
ContentId.unwrap = cases ContentId t -> t

-- ============================================================
-- Abilities — abstract effects the saga depends on
-- ============================================================

ability ContentStore where
  getContent  : ContentId ->{ContentStore} Optional Content
  saveContent : Content   ->{ContentStore} ()

ability AIClassifier where
  classify : Text ->{AIClassifier} ModerationDecision

ability Notifier where
  notify : Text -> ModerationDecision ->{Notifier} ()

ability HumanReview where
  waitForDecision : ContentId ->{HumanReview} ModerationDecision

-- ============================================================
-- Moderation saga — written once, runs under any interpreter
-- ============================================================

moderationSaga : Content ->{HumanReview, AIClassifier, Notifier, ContentStore} ()
moderationSaga content =
  use Content.status set
  saveContent (set Submitted content)
  decision = AIClassifier.classify (Content.text content)
  match decision with
    Escalate _ ->
      saveContent (set (PendingHumanReview decision) content)
      humanDecision = waitForDecision (Content.id content)
      saveContent (set (Resolved humanDecision) content)
      notify (Content.authorId content) humanDecision
    _ ->
      saveContent (set (AutoModerated decision) content)
      notify (Content.authorId content) decision

-- ============================================================
-- Serialization — JSON and SQLite row codecs
-- ============================================================

ModerationDecision.toJson : ModerationDecision -> Json
ModerationDecision.toJson = cases
  Approve         -> Json.object [("type", Json.text "Approve")]
  Reject reason   -> Json.object [("type", Json.text "Reject"), ("reason", Json.text reason)]
  Escalate reason -> Json.object [("type", Json.text "Escalate"), ("reason", Json.text reason)]

ContentStatus.toJson : ContentStatus -> Json
ContentStatus.toJson = cases
  Submitted            -> Json.object [("type", Json.text "Submitted")]
  AutoModerated d      -> Json.object [("type", Json.text "AutoModerated"), ("decision", ModerationDecision.toJson d)]
  PendingHumanReview d -> Json.object [("type", Json.text "PendingHumanReview"), ("decision", ModerationDecision.toJson d)]
  Resolved d           -> Json.object [("type", Json.text "Resolved"), ("decision", ModerationDecision.toJson d)]

Content.toJson : Content -> Json
Content.toJson c =
  Json.object
    [ ("id",        Json.text (ContentId.unwrap (Content.id c)))
    , ("authorId",  Json.text (Content.authorId c))
    , ("text",      Json.text (Content.text c))
    , ("createdAt", Json.nat  (Content.createdAt c))
    , ("status",    ContentStatus.toJson (Content.status c))
    ]

SubmitRequest.decode : Text ->{Exception} (ContentId, Text, Text)
SubmitRequest.decode body =
  decoder = do
    use Decoder text
    use Decoder.object at!
    cid      = at! "id"       text
    authorId = at! "authorId" text
    txt      = at! "text"     text
    (ContentId cid, authorId, txt)
  Decoder.run decoder body

ReviewRequest.decode : Text ->{Exception} ModerationDecision
ReviewRequest.decode body =
  decoder = do
    use Decoder text
    use Text ++
    use Decoder.object at!
    decision = at! "decision" text
    match decision with
      "Approve" -> Approve
      "Reject"  ->
        reason = at! "reason" text
        Reject reason
      _         -> Decoder.fail ("Unknown decision: " ++ decision)
  Decoder.run decoder body

ModerationDecision.toRow : ModerationDecision -> (Text, Optional Text)
ModerationDecision.toRow = cases
  Approve         -> ("Approve",  None)
  Reject reason   -> ("Reject",   Some reason)
  Escalate reason -> ("Escalate", Some reason)

ModerationDecision.fromRow : Text -> Optional Text -> ModerationDecision
ModerationDecision.fromRow tag reason = match tag with
  "Approve" -> Approve
  "Reject"  -> Reject (Optional.getOrElse "" reason)
  _         -> Escalate (Optional.getOrElse "" reason)

ContentStatus.toRow : ContentStatus -> (Text, Optional Text, Optional Text)
ContentStatus.toRow = cases
  Submitted ->
    ("Submitted", None, None)
  AutoModerated d ->
    (decTag, decReason) = ModerationDecision.toRow d
    ("AutoModerated", Some decTag, decReason)
  PendingHumanReview d ->
    (decTag, decReason) = ModerationDecision.toRow d
    ("PendingHumanReview", Some decTag, decReason)
  Resolved d ->
    (decTag, decReason) = ModerationDecision.toRow d
    ("Resolved", Some decTag, decReason)

ContentStatus.fromRow : Text -> Optional Text -> Optional Text -> ContentStatus
ContentStatus.fromRow status decTag decReason = match status with
  "AutoModerated" ->
    d = ModerationDecision.fromRow (Optional.getOrElse "Approve" decTag) decReason
    AutoModerated d
  "PendingHumanReview" ->
    d = ModerationDecision.fromRow (Optional.getOrElse "Approve" decTag) decReason
    PendingHumanReview d
  "Resolved" ->
    d = ModerationDecision.fromRow (Optional.getOrElse "Approve" decTag) decReason
    Resolved d
  _ -> Submitted

-- ============================================================
-- Pure stub interpreters — for testing, no IO
-- ============================================================

AIClassifier.runPure : ModerationDecision -> '{g, AIClassifier} a ->{g} a
AIClassifier.runPure decision action =
  go = cases
    { a }                            -> a
    { AIClassifier.classify _ -> k } -> handle k decision with go
  handle action() with go

ContentStore.runPure : Map ContentId Content -> '{g, ContentStore} a ->{g} (Map ContentId Content, a)
ContentStore.runPure initialStore action =
  go store = cases
    { a }                   -> (store, a)
    { getContent cid -> k } -> handle k (Map.get cid store) with go store
    { saveContent c -> k }  -> handle k() with go (Map.insert (Content.id c) c store)
  handle action() with go initialStore

Notifier.runPure : '{g, Notifier} a ->{g} ([(Text, ModerationDecision)], a)
Notifier.runPure action =
  use List :+
  go notifs = cases
    { a }                             -> (notifs, a)
    { notify authorId decision -> k } -> handle k() with go (notifs :+ (authorId, decision))
  handle action() with go []

HumanReview.runPure : ModerationDecision -> '{g, HumanReview} a ->{g} a
HumanReview.runPure decision action =
  go = cases
    { a }                      -> a
    { waitForDecision _ -> k } -> handle k decision with go
  handle action() with go

Saga.runTest : Map ContentId Content -> ModerationDecision -> ModerationDecision -> Content -> (Map ContentId Content, [(Text, ModerationDecision)])
Saga.runTest initialStore aiDecision humanDecision content =
  noHumanReview = do HumanReview.runPure humanDecision do moderationSaga content
  noAI = do AIClassifier.runPure aiDecision noHumanReview
  (finalStore, (notifs, _)) = ContentStore.runPure initialStore do Notifier.runPure noAI
  (finalStore, notifs)

-- ============================================================
-- SQLite ContentStore interpreter
-- ============================================================

ContentStore.initDb : Sqlite.DB ->{IO, Exception} ()
ContentStore.initDb db =
  Sqlite.DB.execute db "CREATE TABLE IF NOT EXISTS content (id TEXT PRIMARY KEY, author_id TEXT NOT NULL, text_content TEXT NOT NULL, created_at INTEGER NOT NULL, status TEXT NOT NULL, decision TEXT, decision_reason TEXT, awakeable_id TEXT)"

ContentStore.sqliteGet : Sqlite.DB -> ContentId ->{IO, Exception} Optional Content
ContentStore.sqliteGet db cid =
  cidText = ContentId.unwrap cid
  stmt = Sqlite.PreparedStatement.prepare db "SELECT id, author_id, text_content, created_at, status, decision, decision_reason FROM content WHERE id = ?"
  Sqlite.PreparedStatement.bind stmt 0 (Sqlite.Value.Text cidText)
  colText i =
    match Sqlite.PreparedStatement.column stmt i with
      Sqlite.Value.Text t -> t
      _ -> ""
  colTextOpt i =
    match Sqlite.PreparedStatement.column stmt i with
      Sqlite.Value.Text t -> Some t
      _ -> None
  result = match Sqlite.PreparedStatement.step stmt with
    Sqlite.StepResult.Done -> None
    Sqlite.StepResult.Row ->
      id'       = colText 0
      authorId  = colText 1
      txt       = colText 2
      createdAt =
        match Sqlite.PreparedStatement.column stmt 3 with
          Sqlite.Value.Integer i -> Optional.getOrElse 0 (Int.toNat i)
          _ -> 0
      status    = colText 4
      decTag    = colTextOpt 5
      decReason = colTextOpt 6
      st = ContentStatus.fromRow status decTag decReason
      Some (Content (ContentId id') authorId txt createdAt st)
  Sqlite.PreparedStatement.finalize stmt
  result

ContentStore.sqliteSave : Sqlite.DB -> Content ->{IO, Exception} ()
ContentStore.sqliteSave db c =
  (status, decTag, decReason) = ContentStatus.toRow (Content.status c)
  stmt = Sqlite.PreparedStatement.prepare db "INSERT OR REPLACE INTO content (id, author_id, text_content, created_at, status, decision, decision_reason) VALUES (?, ?, ?, ?, ?, ?, ?)"
  Sqlite.PreparedStatement.bind stmt 0 (Sqlite.Value.Text (ContentId.unwrap (Content.id c)))
  Sqlite.PreparedStatement.bind stmt 1 (Sqlite.Value.Text (Content.authorId c))
  Sqlite.PreparedStatement.bind stmt 2 (Sqlite.Value.Text (Content.text c))
  Sqlite.PreparedStatement.bind stmt 3 (Sqlite.Value.Integer (Nat.toInt (Content.createdAt c)))
  Sqlite.PreparedStatement.bind stmt 4 (Sqlite.Value.Text status)
  optToValue opt =
    match opt with
      None   -> Sqlite.Value.Null
      Some t -> Sqlite.Value.Text t
  Sqlite.PreparedStatement.bind stmt 5 (optToValue decTag)
  Sqlite.PreparedStatement.bind stmt 6 (optToValue decReason)
  _ = Sqlite.PreparedStatement.step stmt
  Sqlite.PreparedStatement.finalize stmt

ContentStore.saveAwakeableId : Sqlite.DB -> ContentId -> Text ->{IO, Exception} ()
ContentStore.saveAwakeableId db cid awakeId =
  stmt = Sqlite.PreparedStatement.prepare db "UPDATE content SET awakeable_id = ? WHERE id = ?"
  Sqlite.PreparedStatement.bind stmt 0 (Sqlite.Value.Text awakeId)
  Sqlite.PreparedStatement.bind stmt 1 (Sqlite.Value.Text (ContentId.unwrap cid))
  _ = Sqlite.PreparedStatement.step stmt
  Sqlite.PreparedStatement.finalize stmt

ContentStore.loadAwakeableId : Sqlite.DB -> ContentId ->{IO, Exception} Optional Text
ContentStore.loadAwakeableId db cid =
  stmt = Sqlite.PreparedStatement.prepare db "SELECT awakeable_id FROM content WHERE id = ?"
  Sqlite.PreparedStatement.bind stmt 0 (Sqlite.Value.Text (ContentId.unwrap cid))
  result = match Sqlite.PreparedStatement.step stmt with
    Sqlite.StepResult.Done -> None
    Sqlite.StepResult.Row ->
      match Sqlite.PreparedStatement.column stmt 0 with
        Sqlite.Value.Text t -> Some t
        _ -> None
  Sqlite.PreparedStatement.finalize stmt
  result

ContentStore.sqliteHandler : Sqlite.DB -> '{g, ContentStore} a ->{g, IO, Exception} a
ContentStore.sqliteHandler db action =
  go = cases
    { a } -> a
    { ContentStore.getContent cid -> k } ->
      handle k (ContentStore.sqliteGet db cid) with go
    { ContentStore.saveContent c -> k } ->
      ContentStore.sqliteSave db c
      handle k () with go
  handle action() with go

-- ============================================================
-- Direct-mode interpreters
-- ============================================================

AIClassifier.approveAll : '{g, AIClassifier} a ->{g} a
AIClassifier.approveAll action =
  go = cases
    { a } -> a
    { AIClassifier.classify _ -> k } -> handle k Approve with go
  handle action() with go

Notifier.printHandler : '{g, Notifier} a ->{g, IO, Exception} a
Notifier.printHandler action =
  go = cases
    { a } -> a
    { Notifier.notify authorId decision -> k } ->
      (decTag, _) = ModerationDecision.toRow decision
      printLine ("notify: " Text.++ authorId Text.++ " → " Text.++ decTag)
      handle k () with go
  handle action() with go

-- ============================================================
-- Restate interpreters — durable, journaled execution
-- ============================================================

AIClassifier.restateHandler : '{g, AIClassifier} a ->{g, Restate.Ctx, IO, Exception} a
AIClassifier.restateHandler action =
  go = cases
    { a } -> a
    { AIClassifier.classify _ -> k } ->
      bs = ctx.run "classify" do Text.toUtf8 "Approve"
      decision = ModerationDecision.fromRow (Text.fromUtf8 bs) None
      handle k decision with go
  handle action() with go

Notifier.restateHandler : '{g, Notifier} a ->{g, Restate.Ctx, IO, Exception} a
Notifier.restateHandler action =
  go = cases
    { a } -> a
    { Notifier.notify authorId decision -> k } ->
      (decTag, _) = ModerationDecision.toRow decision
      _ = ctx.run "notify" do
        printLine ("notify: " Text.++ authorId Text.++ " → " Text.++ decTag)
        Text.toUtf8 ""
      handle k () with go
  handle action() with go

ContentStore.restateHandler : Sqlite.DB -> '{g, ContentStore} a ->{g, Restate.Ctx, IO, Exception} a
ContentStore.restateHandler db action =
  go = cases
    { a } -> a
    { ContentStore.getContent cid -> k } ->
      content = ContentStore.sqliteGet db cid
      handle k content with go
    { ContentStore.saveContent c -> k } ->
      _ = ctx.run ("save-" Text.++ ContentId.unwrap (Content.id c)) do
        ContentStore.sqliteSave db c
        Text.toUtf8 ""
      handle k () with go
  handle action() with go

HumanReview.awakeableHandler : Sqlite.DB -> '{g, HumanReview} a ->{g, Restate.Ctx, IO, Exception} a
HumanReview.awakeableHandler db action =
  go = cases
    { a } -> a
    { HumanReview.waitForDecision cid -> k } ->
      hdl = ctx.awakeable
      awakeId = AwakeableHandle.id hdl
      _ = ctx.run "store-awakeable-id" do
        ContentStore.saveAwakeableId db cid awakeId
        Text.toUtf8 ""
      rawHdl = AwakeableHandle.rawHandle hdl
      notif = ctx.await rawHdl
      decision = match notif with
        NSuccess bs -> ModerationDecision.fromRow (Text.fromUtf8 bs) None
        _ -> Reject "awakeable failed"
      handle k decision with go
  handle action() with go

-- ============================================================
-- Optional: Claude API classifier (swap in for approveAll)
-- ============================================================

AIClassifier.callClaude : Text -> Text ->{Exception, Http} Text
AIClassifier.callClaude apiKey text =
  uri = URI.parse "https://api.anthropic.com/v1/messages"
  msg  = Json.object [("role", Json.text "user"), ("content", Json.text ("Classify this content for moderation. Reply with ONE word only: Approve, Reject, or Escalate.\nContent: " Text.++ text))]
  body = Json.object [("model", Json.text "claude-haiku-4-5-20251001"), ("max_tokens", Json.Number "10"), ("messages", Json.array [msg])]
  req0 = HttpRequest.post uri (Body.fromText (Json.toText body))
  req1 = HttpRequest.addHeader "content-type" "application/json" req0
  req2 = HttpRequest.addHeader "anthropic-version" "2023-06-01" req1
  req  = HttpRequest.addHeader "x-api-key" apiKey req2
  resp = Http.request req
  respBody = HttpResponse.bodyText resp
  decoder = do
    Decoder.object.at! "content" do
      Decoder.array.at! 0 do
        Decoder.object.at! "text" Decoder.text
  Decoder.run decoder respBody

AIClassifier.parseDecisionText : Text -> ModerationDecision
AIClassifier.parseDecisionText t =
  if Text.startsWith "Approve" t then Approve
  else if Text.startsWith "Reject" t then Reject t
  else Escalate t

AIClassifier.claudeDirectHandler : Text -> '{g, AIClassifier} a ->{g, IO, Exception} a
AIClassifier.claudeDirectHandler apiKey action =
  go = cases
    { a } -> a
    { AIClassifier.classify text -> k } ->
      decision = Threads.run do
        decText = handle (AIClassifier.callClaude apiKey text) with Http.handler
        AIClassifier.parseDecisionText decText
      handle k decision with go
  handle action() with go

AIClassifier.claudeRestateHandler : Text -> '{g, AIClassifier} a ->{g, Restate.Ctx, IO, Exception} a
AIClassifier.claudeRestateHandler apiKey action =
  go = cases
    { a } -> a
    { AIClassifier.classify text -> k } ->
      bs = ctx.run "classify" do
        decText = Threads.run do
          handle (AIClassifier.callClaude apiKey text) with Http.handler
        (tag, _) = ModerationDecision.toRow (AIClassifier.parseDecisionText decText)
        Text.toUtf8 tag
      decision = ModerationDecision.fromRow (Text.fromUtf8 bs) None
      handle k decision with go
  handle action() with go

-- ============================================================
-- HTTP helpers
-- ============================================================

bodyText : HttpRequest ->{Exception} Text
bodyText req = match HttpRequest.body req with Body bs -> Text.fromUtf8 bs

jsonOk : Json -> HttpResponse
jsonOk j = HttpResponse.ok (Body.fromText (Json.toText j))

httpError : Nat -> Text -> HttpResponse
httpError code msg =
  HttpResponse.status.set (HttpResponse.Status.Status code msg)
    (HttpResponse.ok (Body.fromText msg))

-- ============================================================
-- HTTP API — direct mode
-- ============================================================

-- POST /content — run saga inline, return 202
Demo.Api.submitHandler : Sqlite.DB -> Handler {IO, Exception}
Demo.Api.submitHandler db = Handler.Handler cases
  req | Routes.post (root Path./ "content") req ->
    (cid, authorId, txt) = SubmitRequest.decode (bodyText req)
    now = Optional.getOrElse 0 (Int.toNat (deprecated.systemTimeMicroseconds() / +1000))
    c = Content cid authorId txt now Submitted
    HumanReview.runPure Approve do
      ContentStore.sqliteHandler db do
        Notifier.printHandler do
          AIClassifier.approveAll do
            moderationSaga c
    HttpResponse.status.set (HttpResponse.Status.Status 202 "Accepted")
      (jsonOk (Json.object [("id", Json.text (ContentId.unwrap cid))]))
  _ -> abort

-- POST /content/:id/review — update DB, notify
Demo.Api.reviewHandler : Sqlite.DB -> Handler {IO, Exception}
Demo.Api.reviewHandler db = Handler.Handler cases
  HttpRequest POST _ (URI _ _ (Path ["content", cid, "review"]) _ _) _ bd ->
    bodyTxt = match bd with Body bs -> Text.fromUtf8 bs
    decision = ReviewRequest.decode bodyTxt
    match ContentStore.sqliteGet db (ContentId cid) with
      None -> HttpResponse.notFound
      Some c ->
        match Content.status c with
          PendingHumanReview _ ->
            ContentStore.sqliteSave db (Content.status.set (Resolved decision) c)
            Notifier.printHandler do
              Notifier.notify (Content.authorId c) decision
            jsonOk (Content.toJson (Content.status.set (Resolved decision) c))
          _ -> httpError 409 "Content is not pending human review"
  _ -> abort

-- ============================================================
-- HTTP API — Restate mode
-- ============================================================

-- POST /content — save to SQLite, fire to Restate ingress
Demo.Api.restateSubmitHandler : Sqlite.DB -> Text -> Handler {IO, Exception}
Demo.Api.restateSubmitHandler db restateIngress = Handler.Handler cases
  req | Routes.post (root Path./ "content") req ->
    (cid, authorId, txt) = SubmitRequest.decode (bodyText req)
    now = Optional.getOrElse 0 (Int.toNat (deprecated.systemTimeMicroseconds() / +1000))
    c = Content cid authorId txt now Submitted
    ContentStore.sqliteHandler db do ContentStore.saveContent c
    cidText = ContentId.unwrap cid
    _ = Threads.run do
      uri = URI.parse (restateIngress Text.++ "/ModerationService/moderate")
      rq = HttpRequest.post uri (Body.fromText cidText)
      rq1 = HttpRequest.addHeader "content-type" "application/octet-stream" rq
      handle Http.request rq1 with Http.handler
    HttpResponse.status.set (HttpResponse.Status.Status 202 "Accepted")
      (jsonOk (Json.object [("id", Json.text cidText)]))
  _ -> abort

-- POST /content/:id/review — resolve the Restate awakeable
Demo.Api.restateReviewHandler : Sqlite.DB -> Text -> Handler {IO, Exception}
Demo.Api.restateReviewHandler db restateIngress = Handler.Handler cases
  HttpRequest POST _ (URI _ _ (Path ["content", cid, "review"]) _ _) _ bd ->
    bodyTxt = match bd with Body bs -> Text.fromUtf8 bs
    decision = ReviewRequest.decode bodyTxt
    (decTag, _) = ModerationDecision.toRow decision
    match ContentStore.loadAwakeableId db (ContentId cid) with
      None -> httpError 409 "Content not pending human review"
      Some awakeId ->
        _ = Threads.run do
          uri = URI.parse (restateIngress Text.++ "/restate/awakeables/" Text.++ awakeId Text.++ "/resolve")
          rq = HttpRequest.post uri (Body.fromText decTag)
          rq1 = HttpRequest.addHeader "content-type" "application/octet-stream" rq
          handle Http.request rq1 with Http.handler
        jsonOk (Json.object [("id", Json.text cid), ("decision", Json.text decTag)])
  _ -> abort

-- GET /content/:id — shared between both modes
Demo.Api.getHandler : Sqlite.DB -> Handler {IO, Exception}
Demo.Api.getHandler db = Handler.Handler cases
  HttpRequest GET _ (URI _ _ (Path ["content", cid]) _ _) _ _ ->
    match ContentStore.sqliteGet db (ContentId cid) with
      None   -> HttpResponse.notFound
      Some c -> jsonOk (Content.toJson c)
  _ -> abort

-- ============================================================
-- Entry points
-- ============================================================

Demo.Api.main : '{IO, Exception} ()
Demo.Api.main = do
  dbPath = getEnv "DB_PATH"
  db     = Sqlite.DB.open (FilePath dbPath)
  ContentStore.initDb db
  apiPort = match IO.getEnv.impl "API_PORT" with
    Right p -> p
    Left _  -> "8080"
  config = Config.port.set (Port apiPort) Config.default
  serve routes =
    Threads.run do
      Config.serve routes config
      Promise.read (Promise.new())
  match IO.getEnv.impl "RESTATE_INGRESS" with
    Left _ ->
      r0 = Routes.default <<< Demo.Api.submitHandler db
      r1 = r0 <<< Demo.Api.getHandler db
      serve (r1 <<< Demo.Api.reviewHandler db)
    Right ingress ->
      r0 = Routes.default <<< Demo.Api.restateSubmitHandler db ingress
      r1 = r0 <<< Demo.Api.getHandler db
      serve (r1 <<< Demo.Api.restateReviewHandler db ingress)

Demo.Worker.moderationHandler : Sqlite.DB -> '{IO, Restate.State, Restate.Ctx, Exception} Bytes
Demo.Worker.moderationHandler db = do
  inp = ctx.input
  cidText = Text.fromUtf8 (Input.inputBytes inp)
  c = match ContentStore.sqliteGet db (ContentId cidText) with
    None    -> bug ("Content not found: " Text.++ cidText)
    Some c' -> c'
  HumanReview.awakeableHandler db do
    ContentStore.restateHandler db do
      Notifier.restateHandler do
        AIClassifier.restateHandler do
          moderationSaga c
  Text.toUtf8 "ok"

Demo.Worker.main : '{IO, Exception} ()
Demo.Worker.main = do
  dbPath = getEnv "DB_PATH"
  db     = Sqlite.DB.open (FilePath dbPath)
  ContentStore.initDb db
  hdl = HandlerDef.HandlerDef "moderate" (Demo.Worker.moderationHandler db)
  svc = ServiceDef.ServiceDef "ModerationService" RsService [hdl]
  Threads.run do
    Endpoint.serve 9080 [svc]
    Promise.read (Promise.new())

-- Combined entry point: runs worker (port 9080) and API (API_PORT, default 8081)
-- in a single UCM process to avoid the codebase lock between two `ucm run` calls.
-- Env vars: DB_PATH (required), API_PORT (default 8081), RESTATE_INGRESS (default http://localhost:8080)
Demo.Restate.main : '{IO, Exception} ()
Demo.Restate.main = do
  dbPath  = getEnv "DB_PATH"
  db      = Sqlite.DB.open (FilePath dbPath)
  ContentStore.initDb db
  apiPort = match IO.getEnv.impl "API_PORT" with
    Right p -> p
    Left _  -> "8081"
  ingress = match IO.getEnv.impl "RESTATE_INGRESS" with
    Right i -> i
    Left _  -> "http://localhost:8080"
  hdl = HandlerDef.HandlerDef "moderate" (Demo.Worker.moderationHandler db)
  svc = ServiceDef.ServiceDef "ModerationService" RsService [hdl]
  Threads.run do
    Endpoint.serve 9080 [svc]
    r0 = Routes.default <<< Demo.Api.restateSubmitHandler db ingress
    r1 = r0 <<< Demo.Api.getHandler db
    Config.serve (r1 <<< Demo.Api.restateReviewHandler db ingress) (Config.port.set (Port apiPort) Config.default)
    Promise.read (Promise.new())

-- ============================================================
-- Tests
-- ============================================================

moderationSaga.tests.approve : [Result]
moderationSaga.tests.approve =
  use test ensureEqual
  content = Content (ContentId "c1") "alice" "hello world" 0 Submitted
  (store, notifs) = Saga.runTest Map.empty Approve Approve content
  test.verify do
    ensureEqual (Some (Content.status.set (AutoModerated Approve) content)) (Map.get (ContentId "c1") store)
    ensureEqual [("alice", Approve)] notifs

moderationSaga.tests.reject : [Result]
moderationSaga.tests.reject =
  use test ensureEqual
  content = Content (ContentId "c2") "bob" "buy cheap pills" 0 Submitted
  (store, notifs) = Saga.runTest Map.empty (Reject "spam") Approve content
  test.verify do
    ensureEqual (Some (Content.status.set (AutoModerated (Reject "spam")) content)) (Map.get (ContentId "c2") store)
    ensureEqual [("bob", Reject "spam")] notifs

moderationSaga.tests.escalate : [Result]
moderationSaga.tests.escalate =
  use test ensureEqual
  content = Content (ContentId "c3") "carol" "maybe ok?" 0 Submitted
  humanDecision = Approve
  (store, notifs) = Saga.runTest Map.empty (Escalate "uncertain") humanDecision content
  test.verify do
    ensureEqual (Some (Content.status.set (Resolved Approve) content)) (Map.get (ContentId "c3") store)
    ensureEqual [("carol", Approve)] notifs

ModerationDecision.toJson.tests.approve : [Result]
ModerationDecision.toJson.tests.approve =
  test.verify do
    test.ensureEqual (Json.object [("type", Json.text "Approve")]) (ModerationDecision.toJson Approve)

ModerationDecision.toJson.tests.reject : [Result]
ModerationDecision.toJson.tests.reject =
  test.verify do
    test.ensureEqual
      (Json.object [("type", Json.text "Reject"), ("reason", Json.text "spam")])
      (ModerationDecision.toJson (Reject "spam"))

ModerationDecision.toJson.tests.escalate : [Result]
ModerationDecision.toJson.tests.escalate =
  test.verify do
    test.ensureEqual
      (Json.object [("type", Json.text "Escalate"), ("reason", Json.text "uncertain")])
      (ModerationDecision.toJson (Escalate "uncertain"))

ReviewRequest.decode.tests.approve : [Result]
ReviewRequest.decode.tests.approve =
  test.verify do
    test.ensureEqual Approve (ReviewRequest.decode "{\"decision\":\"Approve\"}")

ReviewRequest.decode.tests.reject : [Result]
ReviewRequest.decode.tests.reject =
  test.verify do
    test.ensureEqual (Reject "spam") (ReviewRequest.decode "{\"decision\":\"Reject\",\"reason\":\"spam\"}")

SubmitRequest.decode.tests.example : [Result]
SubmitRequest.decode.tests.example = test.verify do
  body = "{\"id\":\"c1\",\"authorId\":\"alice\",\"text\":\"hello world\"}"
  test.ensureEqual (ContentId "c1", "alice", "hello world") (SubmitRequest.decode body)
